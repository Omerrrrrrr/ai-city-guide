DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/aicityguide
PORT=4000
# Optional until AI recommendations are enabled.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Optional when both AI providers are configured.
AI_PROVIDER=openai
# Optional until Google-based hours preview is enabled in Hours Review.
GOOGLE_MAPS_API_KEY=
APP_URL=http://localhost:4000
# Optional: enables GET /weather endpoint (proxies OpenWeatherMap). Free tier at openweathermap.org
OPENWEATHER_API_KEY=
# Required to enable /admin/* routes (image review, hours review). Generate with:
# node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Without this set, all /admin/* routes return 503.
ADMIN_API_TOKEN=
# Comma-separated list of allowed browser origins (web build only; native app calls are unaffected).
# Defaults to localhost dev ports when unset.
CORS_ORIGINS=

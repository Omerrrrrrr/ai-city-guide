{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "seed": "ts-node-dev --transpile-only src/seed.ts",
    "images:discover": "ts-node-dev --exit-child --transpile-only src/images-discover.ts",
    "images:list": "ts-node-dev --exit-child --transpile-only src/images-list.ts",
    "images:approve": "ts-node-dev --exit-child --transpile-only src/images-approve.ts",
    "images:reject": "ts-node-dev --exit-child --transpile-only src/images-reject.ts",
    "images:apply": "ts-node-dev --exit-child --transpile-only src/images-apply.ts",
    "test": "npm run build && node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@duckdb/node-api": "^1.5.4-r.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "ai": "^6.0.116",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.0.0",
    "pg": "^8.13.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  }
}
